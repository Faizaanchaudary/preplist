# Data layer: mock | firebase
# mock  = local in-memory data (src/mocks/data) — no Firebase connection
# firebase = live Firestore/Auth/Storage (requires VITE_FIREBASE_* below)
VITE_DATA_SOURCE=mock

# Firebase client config — replace with values from Firebase Console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firestore seed script (npm run seed:firestore) — not used by the Vite app
# Place serviceAccountKey.json in project root OR set GOOGLE_APPLICATION_CREDENTIALS
# SEED_USER_PASSWORD=PrepList123!
# FIREBASE_PROJECT_ID=
